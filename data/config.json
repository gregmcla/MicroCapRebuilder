{
  "mode": "live",
  "paper_trading": {
    "enabled": false,
    "simulated_fill_delay_pct": 0.1,
    "simulated_slippage_pct": 0.05,
    "paper_data_suffix": "_paper"
  },
  "starting_capital": 50000.0,
  "risk_per_trade_pct": 10.0,
  "max_position_pct": 15.0,
  "max_positions": 999,
  "default_stop_loss_pct": 8.0,
  "default_take_profit_pct": 20.0,
  "volatility_lookback_days": 20,
  "benchmark_symbol": "^RUT",
  "fallback_benchmark": "IWM",
  "chart_days": 30,

  "scoring": {
    "default_weights": {
      "momentum": 0.25,
      "volatility": 0.18,
      "volume": 0.12,
      "relative_strength": 0.20,
      "mean_reversion": 0.10,
      "rsi": 0.15
    },
    "regime_weights": {
      "BULL": {
        "momentum": 0.28,
        "volatility": 0.12,
        "volume": 0.12,
        "relative_strength": 0.23,
        "mean_reversion": 0.08,
        "rsi": 0.17
      },
      "SIDEWAYS": {
        "momentum": 0.18,
        "volatility": 0.22,
        "volume": 0.12,
        "relative_strength": 0.18,
        "mean_reversion": 0.15,
        "rsi": 0.15
      },
      "BEAR": {
        "momentum": 0.12,
        "volatility": 0.25,
        "volume": 0.12,
        "relative_strength": 0.13,
        "mean_reversion": 0.20,
        "rsi": 0.18
      }
    },
    "min_score_threshold": {
      "BULL": 40.0,
      "SIDEWAYS": 50.0,
      "BEAR": 60.0
    },
    "momentum": {
      "multi_timeframe_enabled": true,
      "timeframes": {
        "short": {"days": 5, "weight": 0.20},
        "medium": {"days": 20, "weight": 0.50},
        "long": {"days": 60, "weight": 0.30}
      },
      "alignment_bonus_max": 15,
      "acceleration_bonus": 10
    },
    "rsi": {
      "enabled": true,
      "period": 14,
      "thresholds": {
        "oversold": 30,
        "overbought": 70,
        "extreme_overbought": 80
      },
      "hard_filter_above": 85
    }
  },

  "risk_management": {
    "capital_preservation": {
      "enabled": true,
      "triggers": {
        "drawdown_threshold_pct": 10.0,
        "risk_score_threshold": 40,
        "regime_bear_auto_enable": true
      },
      "actions": {
        "halt_new_buys": true,
        "tighten_stops_pct": 5.0,
        "reduce_position_size_multiplier": 0.5
      }
    }
  },

  "learning": {
    "enabled": true,
    "review_period_trades": 30,
    "max_weight_change_pct": 5.0,
    "min_trades_for_adjustment": 10,
    "confidence_multiplier_enabled": true,
    "confidence_min": 0.5,
    "confidence_max": 1.5
  },

  "data_provider": {
    "primary": "yfinance",
    "fallback": "alpha_vantage",
    "alpha_vantage_api_key": "",
    "cache_minutes": 15,
    "retry_count": 3
  },

  "discovery": {
    "enabled": true,
    "run_frequency": "weekly",
    "scan_types": {
      "momentum_breakouts": true,
      "oversold_bounces": true,
      "sector_leaders": true,
      "volume_anomalies": false
    },
    "filters": {
      "min_market_cap_m": 300,
      "max_market_cap_m": 5000,
      "min_avg_volume": 200000,
      "min_price": 5.0,
      "max_price": 500.0
    },
    "watchlist": {
      "max_tickers": 150,
      "stale_days_threshold": 30,
      "core_tickers_file": "data/core_watchlist.jsonl"
    }
  }
}
