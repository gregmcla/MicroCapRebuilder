__pycache__/
*.py[cod]
.venv/
env/
data/*.csv
data/*.json
data/shared_scan_cache/
data/news_cache/
!data/config.json
!data/curated_universe.json
!data/portfolios.json

# Per-portfolio operational data — all CSVs, JSONL, scan caches, and status
# files are runtime state and MUST NOT be committed. Only config.json is tracked.
data/portfolios/*/*.csv
data/portfolios/*/*.jsonl
data/portfolios/*/*.json
!data/portfolios/*/config.json
# Decision Trace files (per-analyze-cycle JSON + .index.jsonl) — runtime state
data/portfolios/*/decisions/
data/pipeline_status/
data/telegram/
data/yf_cache/
logs/
reports/
charts/
backup/

# Secrets - NEVER commit these
.env
.env.*
*.secret
secrets/
.worktrees/

# Cron logs
cron/logs/
.superpowers/

# /design-sync — staged converter scripts, build output, and machine state
.ds-sync/
ds-bundle/
.design-sync/.cache/
.design-sync/learnings/
.design-sync/node_modules
dashboard/dist/styles.css
